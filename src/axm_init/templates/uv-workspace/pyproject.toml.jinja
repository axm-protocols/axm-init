[project]
name = "{{ workspace_name }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_min_version }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.uv.workspace]
members = ["packages/*"]

[tool.ruff]
target-version = "py{{ python_min_version | replace('.', '') }}"
line-length = 99

[tool.ruff.lint]
select = ["E", "F", "I", "N", "UP", "B", "C4", "S", "T20", "RUF"]
per-file-ignores = { "tests/**" = ["S101"] }

[tool.pytest.ini_options]
testpaths = ["packages"]
addopts = "-q --import-mode=importlib"

[tool.coverage.run]
source_pkgs = []

[tool.coverage.report]
show_missing = true
fail_under = 80

[tool.mypy]
python_version = "{{ python_min_version }}"
strict = true
warn_unused_configs = true

[tool.git-cliff.changelog]
header = "# Changelog\n\n"
body = "{% for group, commits in commits | group_by(attribute=\"group\") %}\n## {{ group }}\n{% for commit in commits %}\n- {{ commit.message }}{% endfor %}\n{% endfor %}"
trim = true

[tool.git-cliff.git]
conventional_commits = true
